{
  "name": "ditto-mcp-server",
  "version": "0.1.2-canary.0",
  "description": "Model Context Protocol server for Ditto DQL with capability gating",
  "type": "module",
  "bin": {
    "ditto-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js stdio",
    "dev": "node --watch --loader ts-node/esm src/index.ts stdio",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx --cache",
    "lint:check": "yarn lint --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "yarn build"
  },
  "main": "./dist/index.js",
  "sideEffects": false,
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "commander": "^12.1.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^20.16.11",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.44.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "ditto",
    "dql",
    "ai",
    "agent",
    "cursor",
    "claude",
    "vscode"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aron-henrique/ditto-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/aron-henrique/ditto-mcp/issues"
  },
  "homepage": "https://github.com/aron-henrique/ditto-mcp#readme",
  "publishConfig": {
    "access": "public"
  }
}